{
  "name": "supabase-backend",
  "version": "1.0.0",
  "description": "Rental platform backend using Supabase",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "seed:test-user": "ts-node-dev --transpile-only scripts/seedTestUser.ts",
    "seed:register-test": "ts-node-dev --transpile-only scripts/registerTestUser.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "zod": "^4.1.12",
    "swagger-ui-express": "^5.0.0",
    "swagger-jsdoc": "^6.2.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^2.0.5"
  }
}